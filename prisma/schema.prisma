generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  STUDENT
  SECRETARIAT
  IT_STAFF
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  firstName String   @db.VarChar(100)
  lastName  String   @db.VarChar(100)
  role      Role

  createdAt DateTime  @default(now())
  lastLogin DateTime?

  student     Student?
  secretariat Secretariat?
  admin       Admin?

  reservations             Reservation[]     @relation("ReservedBy")
  reviewedReservations     Reservation[]     @relation("ReviewedBy")

  rentalsAsStudent         Rental[]          @relation("RentedBy")
  rentalsAsIssuer          Rental[]          @relation("IssuedBy")
  rentalsAsReceiver        Rental[]          @relation("ReceivedBy")

  rentalExtensionsReviewed RentalExtension[] @relation("ExtensionReviewer")

  reportedFaults           EquipmentFault[]  @relation("FaultReporter")
  resolvedFaults           EquipmentFault[]  @relation("FaultResolver")
  faultPhotosUploaded      FaultPhoto[]      @relation("FaultPhotoUploader")

  inspections              RentalInspection[] @relation("InspectionCreator")
}

model Student {
  userId       String @id
  indexNr      String @unique @db.VarChar(8)
  fieldOfStudy String @db.VarChar(100)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Secretariat {
  userId  String @id
  roomNr  String @db.VarChar(10)
  faculty String @db.VarChar(100)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum AdminAccessLevel {
  PROGRAMMER
  MANAGING
}

model Admin {
  userId      String           @id
  accessLevel AdminAccessLevel

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}


model EquipmentCategory {
  id          String @id @default(uuid())
  name        String @unique @db.VarChar(100)
  description String @db.VarChar(500)

  equipment          Equipment[]
  categoryAttributes CategoryAttribute[]
}

enum EquipmentStatus {
  AVAILABLE
  RENTED
  MAINTENANCE
  RETIRED
}

model Equipment {
  id           String          @id @default(uuid())
  name         String          @db.VarChar(100)
  serialNumber String?         @db.VarChar(100)
  inventoryNumber String       @unique @db.VarChar(50)
  categoryId   String
  status       EquipmentStatus @default(AVAILABLE)
  createdAt    DateTime        @default(now())

  category     EquipmentCategory @relation(fields: [categoryId], references: [id])
  values       EquipmentValue[]
  reservations Reservation[]
  rentals      Rental[]
  faults       EquipmentFault[]
}

enum AttributeType {
  TEXT
  NUMBER
  SELECT
  DATE
  BOOLEAN
}

model Attribute {
  id   String        @id @default(uuid())
  name String        @unique @db.VarChar(100)
  type AttributeType
  unit String?       @db.VarChar(5)

  categoryAttributes CategoryAttribute[]
  options            AttributeOption[]
  equipmentValues    EquipmentValue[]
}

model CategoryAttribute {
  id          String  @id @default(uuid())
  categoryId  String
  attributeId String
  required    Boolean @default(false)
  order       Int     @default(0)

  category  EquipmentCategory @relation(fields: [categoryId], references: [id])
  attribute Attribute         @relation(fields: [attributeId], references: [id])

  @@unique([categoryId, attributeId])
}

model AttributeOption {
  id          String @id @default(uuid())
  attributeId String
  value       String @db.VarChar(100)
  order       Int    @default(0)

  attribute       Attribute        @relation(fields: [attributeId], references: [id])
  equipmentValues EquipmentValue[] // potrzebne aby Prisma wiedziała o relacji zwrotnej

  @@unique([attributeId, value])
}

model EquipmentValue {
  id                String  @id @default(uuid())
  equipmentId       String
  attributeId       String
  value             String? @db.VarChar(255) // dla TEXT / NUMBER / DATE / BOOLEAN
  attributeOptionId String?                  // dla SELECT

  equipment       Equipment        @relation(fields: [equipmentId], references: [id], onDelete: Cascade)
  attribute       Attribute        @relation(fields: [attributeId], references: [id])
  attributeOption AttributeOption? @relation(fields: [attributeOptionId], references: [id])

  @@unique([equipmentId, attributeId])
}


enum ReservationStatus {
  PENDING    // czeka na akceptację sekretariatu
  APPROVED   // zaakceptowana, czeka na odbiór
  REJECTED   // odrzucona
  CANCELLED  // anulowana przez studenta
  COMPLETED  // sprzęt odebrany → powstał Rental
}

model Reservation {
  id           String            @id @default(uuid())
  studentId    String
  equipmentId  String
  startDate    DateTime
  endDate      DateTime
  status       ReservationStatus @default(PENDING)
  notes        String?           @db.Text

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  reviewedBy   String?
  reviewedAt   DateTime?
  rejectReason String?  @db.Text

  student   User      @relation("ReservedBy", fields: [studentId], references: [id])
  reviewer  User?     @relation("ReviewedBy", fields: [reviewedBy], references: [id])
  equipment Equipment @relation(fields: [equipmentId], references: [id])

  rental Rental? // powstaje po odebraniu sprzętu
}

enum RentalStatus {
  ACTIVE
  OVERDUE
  RETURNED
  LOST
}

model Rental {
  id          String       @id @default(uuid())
  studentId   String
  equipmentId String
  startDate   DateTime
  dueDate     DateTime
  returnedAt  DateTime?
  status      RentalStatus @default(ACTIVE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  issuedBy   String
  receivedBy String?

  // null = wypożyczenie bezpośrednio na miejscu (bez rezerwacji online)
  reservationId String? @unique

  student     User         @relation("RentedBy", fields: [studentId], references: [id])
  issuer      User         @relation("IssuedBy", fields: [issuedBy], references: [id])
  receiver    User?        @relation("ReceivedBy", fields: [receivedBy], references: [id])
  equipment   Equipment    @relation(fields: [equipmentId], references: [id])
  reservation Reservation? @relation(fields: [reservationId], references: [id])

  extensions  RentalExtension[]
  faults      EquipmentFault[]
  inspections RentalInspection[]
}


enum ExtensionStatus {
  PENDING
  APPROVED
  REJECTED
}

model RentalExtension {
  id           String          @id @default(uuid())
  rentalId     String
  newDueDate   DateTime
  status       ExtensionStatus @default(PENDING)
  requestedAt  DateTime        @default(now())

  reviewedBy   String?
  reviewedAt   DateTime?
  rejectReason String?

  rental   Rental @relation(fields: [rentalId], references: [id], onDelete: Cascade)
  reviewer User?  @relation("ExtensionReviewer", fields: [reviewedBy], references: [id])
}

enum OccurrenceType {
  DURING_USE
  ON_PICKUP
}

enum FaultSeverity {
  MINOR
  MODERATE
  CRITICAL
}

enum FaultStatus {
  OPEN
  IN_REVIEW
  RESOLVED
  DISMISSED
}

model EquipmentFault {
  id          String        @id @default(uuid())
  equipmentId String
  rentalId    String
  reportedBy  String
  description String        @db.Text
  severity    FaultSeverity @default(MINOR)
  status      FaultStatus   @default(OPEN)

  occurredDuring OccurrenceType

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  resolvedBy  String?
  resolvedAt  DateTime?
  resolveNote String?  @db.Text

  equipment Equipment @relation(fields: [equipmentId], references: [id])
  rental    Rental    @relation(fields: [rentalId], references: [id])
  reporter  User      @relation("FaultReporter", fields: [reportedBy], references: [id])
  resolver  User?     @relation("FaultResolver", fields: [resolvedBy], references: [id])

  photos FaultPhoto[]
}

model FaultPhoto {
  id         String   @id @default(uuid())
  faultId    String
  path       String   @db.VarChar(500)
  uploadedBy String
  createdAt  DateTime @default(now())

  fault    EquipmentFault @relation(fields: [faultId], references: [id], onDelete: Cascade)
  uploader User           @relation("FaultPhotoUploader", fields: [uploadedBy], references: [id])
}

enum InspectionType {
  CHECKOUT
  RETURN
}

model RentalInspection {
  id          String         @id @default(uuid())
  rentalId    String
  type        InspectionType
  notes       String?        @db.Text
  inspectedBy String

  createdAt DateTime @default(now())

  rental    Rental  @relation(fields: [rentalId], references: [id], onDelete: Cascade)
  inspector User    @relation("InspectionCreator", fields: [inspectedBy], references: [id])

  photos InspectionPhoto[] @relation("InspectionPhotoRelation")

  @@unique([rentalId, type])
}

model InspectionPhoto {
  id           String   @id @default(uuid())
  inspectionId String
  path         String   @db.VarChar(500)
  createdAt    DateTime @default(now())

  inspection RentalInspection @relation("InspectionPhotoRelation", fields: [inspectionId], references: [id], onDelete: Cascade)
}
